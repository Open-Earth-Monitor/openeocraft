# GPU example — flavor names are cloud-specific. List GPU flavors with:
#   openstack flavor list --long | grep -i gpu

region       = ""
project_name = "openeocraft-gpu"

key_pair_name = "my-keypair"

flavor_name = "gpu.t4.medium"
image_name  = "Ubuntu 22.04"

external_network_name = "public"
floating_ip_pool      = "public"

ssh_cidr_blocks = ["203.0.113.10/32"]
api_cidr_blocks = ["203.0.113.10/32"]

enable_gpu          = true
nvidia_driver_major = 535

docker_cpus      = 8
docker_memory_gb = 30

swap_size_gb             = 0
root_volume_size_gb      = 120
workspace_volume_size_gb = 200

docker_image = "brianpondi/openeocraft:latest"

tags = {
  Environment = "dev"
  Workload    = "gpu"
}
