location     = "eastus"
project_name = "openeocraft-gpu"

# Paste the contents of your ~/.ssh/id_ed25519.pub (or id_rsa.pub).
ssh_public_key = "ssh-ed25519 AAAA... you@host"

# Restrict to your public IP: curl -s ifconfig.me → x.x.x.x/32
ssh_cidr_blocks = ["203.0.113.10/32"]
api_cidr_blocks = ["203.0.113.10/32"]

# GPU defaults: Standard_NC8as_T4_v3 = 8 vCPU, 56 GB RAM, 1x NVIDIA T4
enable_gpu          = true
vm_size             = "Standard_NC8as_T4_v3"
nvidia_driver_major = 535

docker_cpus      = 8
docker_memory_gb = 30

swap_size_gb             = 0
os_disk_size_gb          = 120
workspace_disk_size_gb   = 200

docker_image = "brianpondi/openeocraft:latest"

tags = {
  Environment = "dev"
  Workload    = "gpu"
}
